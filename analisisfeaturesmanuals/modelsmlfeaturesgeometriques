def reducir_features_correlacionadas(df, features, threshold=0.97):
    corr_matrix = df[features].corr().abs()
    upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))

    grupos = []
    ya_asignadas = set()
    usada_como_central = set()
    a_eliminar = set()

    for col in upper.columns:
        if col in ya_asignadas:
            continue

        correladas = upper[col][upper[col] > threshold].index.tolist()
        if correladas:
            grupo = [col] + correladas
            grupo = list(set(grupo))
            grupos.append(grupo)

            representante = None
            for var in grupo:
                if var in usada_como_central:
                    representante = var
                    break
            if not representante:
                representante = grupo[0]
                usada_como_central.add(representante)

            for var in grupo:
                if var != representante:
                    a_eliminar.add(var)

            ya_asignadas.update(grupo)

    print(f"\nReduint {len(set(sum(grupos, [])))} variables correlacionades a {len(usada_como_central)}:")
    for grupo in grupos:
        representante = next((v for v in grupo if v in usada_como_central), grupo[0])
        print(f"Grup: {grupo} → conservant: {representante}")
        for i in range(len(grupo)):
            for j in range(i + 1, len(grupo)):
                v1, v2 = grupo[i], grupo[j]
                corr_value = corr_matrix.loc[v1, v2]
                print(f"    · Correlació entre {v1} i {v2}: {corr_value:.4f}")

    final_features = [f for f in features if f not in a_eliminar]
    return final_features


