def run_grid(name, estimator, param_grid, X, y):
    grid = GridSearchCV(
        estimator=estimator,
        param_grid=param_grid,
        cv=CV,
        scoring=SCORING,
        n_jobs=-1,
        refit=True,
        error_score='raise'
    )
    grid.fit(X, y)
    print(f"\n=== {name} ===")
    print("Millors paràmetres:", grid.best_params_)
    print(f"Millor mitjana CV: {grid.best_score_:.4f}")
    top5 = (pd.DataFrame(grid.cv_results_)[['params', 'mean_test_score', 'std_test_score']]
            .sort_values('mean_test_score', ascending=False)
            .head(5))
    print(top5.to_string(index=False))
    return grid.best_estimator_, grid


def perm_importance_test(model, X_test, y_test, title_prefix):
    perm = permutation_importance(
        model, X_test, y_test,
        n_repeats=N_REPEATS_PERM,
        random_state=RANDOM_STATE,
        scoring=SCORING
    )
    importances = perm.importances_mean
    idx = np.argsort(importances)[::-1]
    feat = [feature_cols[i] for i in idx]
    imp  = importances[idx]
    print(f"\nFeature importances (permutation-based, test) - {title_prefix}:")
    for j in idx:
        print(f"{feature_cols[j]}: {perm.importances_mean[j]:.4f} ± {perm.importances_std[j]:.4f}")
    plt.figure(figsize=(12, 8))
    plt.barh(feat, imp)
    plt.gca().invert_yaxis()
    plt.xlabel('Importància (perm test)')
    plt.title(f'Feature Importance (Permutation - Test) - {title_prefix}')
    plt.tight_layout()
    plt.show()
    return perm


# ── SHAP helpers ──────────────────────────────────────────────
def _shap_to_3d(shap_values, class_names):
    if isinstance(shap_values, list):
        return np.stack(shap_values, axis=-1)
    sv = np.asarray(shap_values)
    if sv.ndim == 2:
        sv = sv[..., np.newaxis]
    return sv


def _boxplots_per_class(abs_shap_3d, feat_names, class_names, prefix, figsize=(12, 6)):
    for i, cname in enumerate(class_names):
        df_shap = pd.DataFrame(abs_shap_3d[:, :, i], columns=feat_names)
        plt.figure(figsize=figsize)
        df_shap.boxplot()
        plt.xticks(rotation=90)
        plt.title(f'{prefix} - Classe {cname}')
        plt.tight_layout()
        plt.show()


def shap_tree(model, X_test, feat_names, class_names, prefix):
    explainer = shap.TreeExplainer(model)
    shap_values = explainer.shap_values(X_test)
    abs_all = np.abs(_shap_to_3d(shap_values, class_names))
    _boxplots_per_class(abs_all, feat_names, class_names, prefix)
    imp_mean = abs_all.mean(axis=(0, 2))
    imp_max  = abs_all.mean(axis=0).max(axis=1)
    return imp_mean, imp_max


def shap_linear(model, X_train, X_test, feat_names, class_names, prefix):
    masker = shap.maskers.Independent(X_train)
    explainer = shap.LinearExplainer(model, masker=masker)
    shap_values = explainer.shap_values(X_test)
    abs_all = np.abs(_shap_to_3d(shap_values, class_names))
    _boxplots_per_class(abs_all, feat_names, class_names, prefix)
    imp_mean = abs_all.mean(axis=(0, 2))
    imp_max  = abs_all.mean(axis=0).max(axis=1)
    return imp_mean, imp_max


def shap_kernel(model, X_train, X_test, feat_names, class_names, prefix,
                bg_kmeans=KMEANS_BG, nsamples=NSAMPLES_KERNEL,
                explain_all=EXPLAIN_ALL_TEST, explain_n=EXPLAIN_TEST_SUBSAMPLE):

    n_clusters = min(bg_kmeans, X_train.shape[0])
    background = shap.kmeans(X_train, n_clusters) if n_clusters >= 2 else X_train

    if explain_all:
        X_exp = X_test
    else:
        rng = np.random.default_rng(RANDOM_STATE)
        sel = rng.choice(X_test.shape[0], min(explain_n, X_test.shape[0]), replace=False)
        X_exp = X_test[sel]

    explainer = shap.KernelExplainer(model.predict_proba, background)
    shap_values = explainer.shap_values(X_exp, nsamples=nsamples)

    abs_all = np.abs(_shap_to_3d(shap_values, class_names))
    _boxplots_per_class(abs_all, feat_names, class_names, prefix)
    imp_mean = abs_all.mean(axis=(0, 2))
    imp_max  = abs_all.mean(axis=0).max(axis=1)
    return imp_mean, imp_max


