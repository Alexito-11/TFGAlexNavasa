    per_class_report('MLP', y_test_enc, y_pred_mlp),
    per_class_report('KNN', y_test_enc, y_pred_knn),
    per_class_report('LR',  y_test_enc, le.transform(y_pred_lr)),
])

best_f1_per_class = (
    per_class.reset_index()
             .rename(columns={'index': 'class'})
             .sort_values(['class', 'f1-score'], ascending=[True, False])
             .groupby('class')
             .head(1)[['class', 'model', 'f1-score']]
)
print("\n=== MILLOR MODEL PER CLASSE (F1) ===")
print(best_f1_per_class.to_string(index=False))


# ── SHAP absoluts per a tots els models (per als gràfics agregats) ──
abs_rf  = np.abs(_shap_to_3d(shap.TreeExplainer(rf_estimator).shap_values(X_all_test),
                             rf_estimator.classes_))
abs_xgb = np.abs(_shap_to_3d(shap.TreeExplainer(xgb_estimator).shap_values(X_all_test),
                             class_names))

explainer_svm = shap.KernelExplainer(svm_estimator.predict_proba,
                                     shap.kmeans(X_all_train, min(KMEANS_BG, X_all_train.shape[0])))
abs_svm = np.abs(_shap_to_3d(explainer_svm.shap_values(X_all_test, nsamples=NSAMPLES_KERNEL),
                             class_names))

explainer_mlp = shap.KernelExplainer(mlp_estimator.predict_proba,
                                     shap.kmeans(X_all_train, min(KMEANS_BG, X_all_train.shape[0])))
abs_mlp = np.abs(_shap_to_3d(explainer_mlp.shap_values(X_all_test, nsamples=NSAMPLES_KERNEL),
                             class_names))

explainer_knn = shap.KernelExplainer(knn_estimator.predict_proba,
                                     shap.kmeans(X_all_train, min(KMEANS_BG, X_all_train.shape[0])))
abs_knn = np.abs(_shap_to_3d(explainer_knn.shap_values(X_all_test, nsamples=NSAMPLES_KERNEL),
                             class_names))

masker = shap.maskers.Independent(X_all_train)
explainer_lr = shap.Explainer(lr_estimator.named_steps['clf'], masker)
abs_lr = np.abs(_shap_to_3d(explainer_lr(X_all_test).values,
                            lr_estimator.named_steps['clf'].classes_))


# ── TOP FEATURES PER CLASSE ───────────────────────────────────
top_counts_per_class = {cls: Counter() for cls in class_names}
shap_abs_all = [abs_rf, abs_xgb, abs_svm, abs_mlp, abs_knn, abs_lr]

for shap_model in shap_abs_all:
    mean_sv = shap_model.mean(axis=0)  # (features, classes)
    for i, cls in enumerate(class_names):
        top5_idx = np.argsort(mean_sv[:, i])[::-1][:5]
        for idx in top5_idx:
            top_counts_per_class[cls][feature_cols[idx]] += 1

max_count_global = max(max(c.values()) for c in top_counts_per_class.values())

fig, axs = plt.subplots(nrows=len(class_names),
                        figsize=(10, 3 * len(class_names)), constrained_layout=True)
for i, cls in enumerate(class_names):
    top_feats = top_counts_per_class[cls].most_common(10)
    feats, counts = zip(*top_feats)
    axs[i].barh(feats, counts)
    axs[i].invert_yaxis()
    axs[i].set_title(f"Top features - {cls}")
    axs[i].set_xlabel("Vegades al top 5")
    axs[i].set_xlim(0, max_count_global)
fig.suptitle("Freqüència d'aparició al Top 5 SHAP per classe (tots els models)", fontsize=14)
plt.show()

df_summary = pd.DataFrame.from_dict(
